# =============================================
# TASLIMA BACKEND — Variables d'environnement
# =============================================

PORT=5000
NODE_ENV=development

# MongoDB Atlas — Remplacer par ton URL
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taslima?retryWrites=true&w=majority

# JWT
JWT_SECRET=taslima_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# CORS — URL de ton frontend
CLIENT_URL=http://localhost:3000

# Identifiants Admin (utilisés par le seed)
ADMIN_NOM=Taslima Admin
ADMIN_TELEPHONE=+221770000001
ADMIN_EMAIL=admin@taslima.sn
ADMIN_PASSWORD=votre_mot_de_passe_admin
